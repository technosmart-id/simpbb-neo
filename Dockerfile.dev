FROM node:22-alpine

# Install libc6-compat for compatibility with some Node.js native modules
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install all dependencies (including devDependencies) to run the dev server
COPY package.json package-lock.json ./
RUN npm ci

# Copy the entire source code into the container
COPY . .

# Ensure permissions for the Next.js cache and uploads if necessary
RUN mkdir -p .next uploads && chown -R node:node .next uploads

# Set environment variables for development mode
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Use the non-root node user for better security, even in dev
USER node

EXPOSE 3000

# Start the Next.js dev server with Turbopack
CMD ["npm", "run", "dev"]
