FROM node:22-alpine

# Add libc6-compat for Turbopack/SWC native bindings compatibility on Alpine
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm ci

# Copy the entire source code
COPY . .

# Expose the standard Next.js port
EXPOSE 3000

# Set environment variables
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NODE_ENV=development

# Run the development server (which uses Turbopack based on your package.json)
CMD ["npm", "run", "dev"]
