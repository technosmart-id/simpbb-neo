# App & Database
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=mysql://user:password@localhost:3306/db_name

# Better Auth
BETTER_AUTH_SECRET=your-random-secret-key-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
SESSION_EXPIRES_IN=604800

# Default Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=your-secure-password

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@yourdomain.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# OAuth (Google)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Captcha (reCAPTCHA v2)
RECAPTCHA_SITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECAPTCHA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Storage (local | s3)
STORAGE_PROVIDER=local
S3_ACCESS_KEY_ID=xxxxxxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxx
S3_REGION=ap-southeast-1
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://your-s3-endpoint.com

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_DIR="./backups"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RUN_ON_START=false

# Override this on Windows: MYSQLDUMP_PATH="C:/Program Files/MySQL/MySQL Server 8.0/bin/mysqldump.exe"
MYSQLDUMP_PATH="/usr/bin/mysqldump"
