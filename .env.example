# App & Database
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=mysql://user:password@localhost:3306/database_name

# Better Auth
BETTER_AUTH_SECRET=change-this-to-a-random-string-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
SESSION_EXPIRES_IN=604800

# Default Admin User
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_NAME=Admin User
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=noreply@yourdomain.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Captcha (reCAPTCHA v3)
RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key

# Storage (local | s3)
STORAGE_PROVIDER=local
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://s3.amazonaws.com

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_DIR="./backups"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RUN_ON_START=false

# mysqldump path (adjust for your system)
# Windows example:
# MYSQLDUMP_PATH="C:/Program Files/MySQL/MySQL Server 8.0/bin/mysqldump.exe"
# Linux/Mac example:
# MYSQLDUMP_PATH=mysqldump
